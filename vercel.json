{
    "version": 2,
    "crons": [
        {
            "path": "/api/newsletter-send",
            "schedule": "0 14 * * 0"
        },
        {
            "path": "/api/health-check",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/newsletter-onboarding",
            "schedule": "0 10 * * *"
        },
        {
            "path": "/api/newsletter-snapshot",
            "schedule": "0 23 * * 6"
        },
        {
            "path": "/api/morning-report",
            "schedule": "0 7 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/api/stock-data/:symbol", "destination": "/api/stock-data?symbol=:symbol" },
        { "source": "/api/newsletter-unsubscribe", "destination": "/api/newsletter?action=unsubscribe" },
        { "source": "/api/check", "destination": "/api/health-check?action=ping" },
        { "source": "/api/tickers", "destination": "/api/batch-stocks?action=tickers" },
        { "source": "/api/(.*)", "destination": "/api/$1" },

        { "source": "/stocks/:symbol", "destination": "/api/stock-data?symbol=:symbol&action=price" },
        { "source": "/sma/:symbol", "destination": "/api/stock-data?symbol=:symbol&action=sma" },
        { "source": "/news/:symbol", "destination": "/api/stock-data?symbol=:symbol&action=news" },
        { "source": "/company-name/:symbol", "destination": "/api/stock-data?symbol=:symbol&action=company-name" },
        { "source": "/fundamentals/:symbol", "destination": "/api/stock-data?symbol=:symbol&action=fundamentals" },
        { "source": "/batch-stocks", "destination": "/api/batch-stocks" },
        { "source": "/login", "destination": "/api/user?action=login" },
        { "source": "/register", "destination": "/api/user?action=register" },
        { "source": "/auth", "destination": "/api/user?action=verify-token" },
        { "source": "/verify-captcha", "destination": "/api/user?action=verify-captcha" },
        
        { "source": "/newsletter/:token", "destination": "/api/newsletter?action=view&token=:token" },
        { "source": "/admin", "destination": "/admin.html" },
        { "source": "/", "destination": "/start.html" },
        { "source": "/start", "destination": "/start.html" },
        { "source": "/app", "destination": "/app.html" },
        { "source": "/imprint", "destination": "/imprint.html" },
        { "source": "/terms", "destination": "/terms.html" },
        { "source": "/about", "destination": "/app.html" },
        { "source": "/screener", "destination": "/app.html" },
        { "source": "/profile", "destination": "/app.html" },
        { "source": "/contact", "destination": "/contact.html" },
        { "source": "/privacy", "destination": "/privacy.html" },
        { "source": "/((?!api/|.*\\..*).*)", "destination": "/app.html" }
    ]
}
